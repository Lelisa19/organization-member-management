# Copy to `.env` and adjust for local development.
DATABASE_URL="file:./prisma/dev.db"
JWT_SECRET="change-me-in-production-use-long-random-string"

# Required for `npm run prisma:seed` — never commit real values to git.
SEED_SUPERADMIN_PASSWORD=""
SEED_DEMO_ORG_ADMIN_PASSWORD=""
# Optional overrides (defaults shown):
# SEED_SUPERADMIN_EMAIL=owner@omms.com
# SEED_DEMO_ORG_ADMIN_EMAIL=admin@membershippro.demo
